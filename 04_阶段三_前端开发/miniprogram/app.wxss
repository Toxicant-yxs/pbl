/* app.wxss - 全局样式 */
page {
  --paper: #f3ece1;
  --paper-2: #ebe2d3;
  --paper-3: #e3d8c4;
  --ink: #1a1612;
  --ink-2: #2a2520;
  --ink-3: #4a4239;
  --ink-4: #8a7f72;
  --line: #1a1612;
  --vermillion: #c8462c;
  --jade: #4a6b4a;
  --ochre: #c8973a;
  background: var(--paper);
  color: var(--ink);
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.container { padding: 0 28rpx; }

/* 排版 */
.h-serif { font-family: "Songti SC", "STSong", serif; font-weight: 700; }
.mono    { font-family: "Menlo", "Consolas", monospace; letter-spacing: 0.1em; }

/* 按钮 */
.btn-primary {
  background: var(--ink);
  color: var(--paper);
  border-radius: 8rpx;
  padding: 28rpx 0;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 0.2em;
}
.btn-primary[disabled] { opacity: 0.4; }

.btn-danger {
  background: var(--vermillion);
  color: var(--paper);
  border-radius: 8rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border: 1rpx solid var(--ink-3);
  color: var(--ink-3);
  margin-right: 8rpx;
  font-family: "Menlo", monospace;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.tag.high { background: var(--vermillion); color: var(--paper); border-color: var(--vermillion); }
.tag.med  { color: var(--ochre); border-color: var(--ochre); }
.tag.low  { color: var(--jade); border-color: var(--jade); }
.tag.cat  { background: var(--ink); color: var(--paper); }

/* 分割线 */
.divider { height: 1rpx; background: var(--ink); }
.divider-dashed { height: 1rpx; background: repeating-linear-gradient(90deg, var(--ink-4) 0 8rpx, transparent 8rpx 16rpx); }

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--ink-4);
}
.empty .ic { font-size: 96rpx; margin-bottom: 24rpx; }
.empty .tx { font-size: 28rpx; letter-spacing: 0.1em; }
