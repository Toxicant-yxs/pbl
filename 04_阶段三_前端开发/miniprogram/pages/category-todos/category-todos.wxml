<view class="page">
  <view class="head">
    <text class="back" bindtap="goBack">← 返回</text>
    <text class="t">{{categoryName}}</text>
    <text class="count">{{todoList.length}} 项</text>
  </view>

  <view class="list" wx:if="{{todoList.length > 0}}">
    <view class="todo {{item.is_completed ? 'done' : ''}}" wx:for="{{todoList}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="check {{item.is_completed ? 'checked' : ''}}" catchtap="toggleComplete" data-id="{{item.id}}" data-completed="{{item.is_completed}}">
        <text wx:if="{{item.is_completed}}">✓</text>
      </view>
      <view class="body">
        <view class="t-title">{{item.title}}</view>
        <view class="meta">
          <text class="tag {{item.priority === 3 ? 'high' : (item.priority === 2 ? 'med' : 'low')}}">{{priorityText[item.priority]}}</text>
          <text class="tag" wx:if="{{item.deadline}}">{{item.deadlineText}}</text>
        </view>
      </view>
      <text class="pin" wx:if="{{item.is_pinned}}">📌</text>
    </view>
  </view>

  <view class="empty" wx:else>
    <view class="ic">▢</view>
    <view class="tx">该分类下暂无待办</view>
  </view>
</view>
