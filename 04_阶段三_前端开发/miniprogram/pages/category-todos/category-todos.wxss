.page { min-height: 100vh; background: var(--paper); }
.head { padding: 24rpx 56rpx 32rpx; display: flex; align-items: center; justify-content: space-between; border-bottom: 1rpx solid var(--ink); }
.head .back { font-size: 24rpx; color: var(--ink-3); }
.head .t { font-family: "Songti SC", serif; font-size: 36rpx; font-weight: 700; }
.head .count { font-size: 22rpx; color: var(--ink-4); letter-spacing: 0.2em; }
.list { padding: 16rpx 56rpx 80rpx; }
.todo { display: flex; gap: 24rpx; padding: 28rpx 0; border-bottom: 1rpx dashed var(--ink-4); align-items: flex-start; }
.check { width: 40rpx; height: 40rpx; border: 3rpx solid var(--ink); border-radius: 50%; flex-shrink: 0; margin-top: 4rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; }
.check.checked { background: var(--vermillion); border-color: var(--vermillion); color: var(--paper); }
.body { flex: 1; min-width: 0; }
.t-title { font-family: "Songti SC", serif; font-size: 30rpx; line-height: 1.3; }
.todo.done .t-title { text-decoration: line-through; color: var(--ink-4); }
.meta { display: flex; gap: 8rpx; margin-top: 12rpx; flex-wrap: wrap; }
.pin { color: var(--vermillion); font-size: 24rpx; margin-left: auto; }
