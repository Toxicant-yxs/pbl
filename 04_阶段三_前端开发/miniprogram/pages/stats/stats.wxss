.page { min-height: 100vh; background: var(--paper); }
.head { padding: 24rpx 56rpx 40rpx; border-bottom: 1rpx solid var(--ink); }
.head .title { font-family: "Songti SC", serif; font-size: 56rpx; font-weight: 900; line-height: 1; }
.head .title .accent { color: var(--vermillion); }
.head .sub { font-size: 20rpx; letter-spacing: 0.4em; color: var(--ink-4); margin-top: 12rpx; }
.body { padding: 40rpx 56rpx 160rpx; }
.ring-wrap { display: flex; justify-content: center; padding: 32rpx 0 48rpx; }
.ring { width: 400rpx; height: 400rpx; position: relative; border-radius: 50%; }
.ring .num { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.ring .num .b { font-family: "Songti SC", serif; font-size: 112rpx; font-weight: 900; }
.ring .num .l { font-size: 20rpx; letter-spacing: 0.4em; color: var(--ink-4); margin-top: 12rpx; }
.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rpx; background: var(--ink); border: 1rpx solid var(--ink); margin-bottom: 48rpx; }
.cell { background: var(--paper); padding: 32rpx; }
.cell .n { font-family: "Songti SC", serif; font-size: 60rpx; font-weight: 700; }
.cell .l { font-size: 18rpx; letter-spacing: 0.4em; color: var(--ink-4); margin-top: 12rpx; }
.cell .d { font-size: 22rpx; color: var(--jade); margin-top: 12rpx; }
.card { border: 1rpx solid var(--ink); padding: 32rpx; }
.card-h { display: flex; justify-content: space-between; margin-bottom: 32rpx; }
.card-h .t { font-family: "Songti SC", serif; font-size: 28rpx; font-weight: 700; }
.card-h .s { font-size: 18rpx; color: var(--ink-4); letter-spacing: 0.4em; }
.bars { display: flex; align-items: flex-end; gap: 16rpx; height: 200rpx; }
.col { flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end; }
.col .b { width: 100%; background: var(--ink); border-radius: 4rpx 4rpx 0 0; }
.col .b.peak { background: var(--vermillion); }
.col .d { font-size: 18rpx; color: var(--ink-4); margin-top: 8rpx; }
