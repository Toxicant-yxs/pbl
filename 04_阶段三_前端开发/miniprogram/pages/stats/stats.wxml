<view class="page">
  <view class="head">
    <view class="title">完成率 <text class="accent">{{completionRate}}%</text></view>
    <view class="sub">本周数据 · WEEKLY</view>
  </view>

  <view class="body">
    <view class="ring-wrap">
      <view class="ring">
        <view class="bg"></view>
        <view class="fg" style="background: conic-gradient(var(--vermillion) 0 {{completionRate}}%, var(--paper-3) {{completionRate}}% 100%);"></view>
        <view class="num">
          <text class="b">{{completionRate}}%</text>
          <text class="l">本周完成率</text>
        </view>
      </view>
    </view>

    <view class="grid">
      <view class="cell">
        <view class="n">{{overview.completed}}</view>
        <view class="l">已完成</view>
        <view class="d">↑ 较上周 +{{delta.completed}}</view>
      </view>
      <view class="cell">
        <view class="n">{{overview.pending}}</view>
        <view class="l">未完成</view>
        <view class="d">↓ 较上周 -{{delta.pending}}</view>
      </view>
      <view class="cell">
        <view class="n">{{overview.streakDays}}</view>
        <view class="l">连续打卡</view>
        <view class="d">days · 天</view>
      </view>
      <view class="cell">
        <view class="n">{{avgPerDay}}</view>
        <view class="l">日均完成</view>
        <view class="d">items / day</view>
      </view>
    </view>

    <view class="card">
      <view class="card-h">
        <text class="t">近 7 日完成趋势</text>
        <text class="s">DAILY</text>
      </view>
      <view class="bars">
        <view class="col" wx:for="{{daily}}" wx:key="date">
          <view class="b {{item.isPeak ? 'peak' : ''}}" style="height: {{item.height}}%"></view>
          <view class="d">{{item.week}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
