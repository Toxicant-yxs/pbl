/* today.wxss */
.page { min-height: 100vh; padding: 32rpx 56rpx 160rpx; background: var(--paper); position: relative; }
.head { margin-bottom: 24rpx; }
.greet { display: flex; justify-content: space-between; align-items: center; margin-bottom: 48rpx; }
.greet .date { font-size: 20rpx; letter-spacing: 0.4em; color: var(--ink-4); font-family: "Menlo", monospace; }
.avatar { width: 72rpx; height: 72rpx; background: var(--ink); color: var(--paper); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 700; }
.title { font-family: "Songti SC", serif; font-size: 88rpx; font-weight: 900; line-height: 1; }
.title .accent { color: var(--vermillion); }
.stats { margin-top: 40rpx; display: flex; border-top: 1rpx solid var(--ink); border-bottom: 1rpx solid var(--ink); }
.stat { flex: 1; padding: 24rpx 0; }
.stat + .stat { border-left: 1rpx solid var(--ink); padding-left: 32rpx; }
.stat .num { font-family: "Songti SC", serif; font-size: 56rpx; font-weight: 700; }
.stat .lbl { font-size: 18rpx; letter-spacing: 0.4em; color: var(--ink-4); margin-top: 8rpx; }
.progress-label { display: flex; justify-content: space-between; padding: 24rpx 0 8rpx; font-size: 20rpx; color: var(--ink-3); font-family: "Menlo", monospace; letter-spacing: 0.2em; }
.progress { height: 8rpx; background: var(--paper-3); border-radius: 4rpx; overflow: hidden; }
.progress .bar { height: 100%; background: var(--vermillion); transition: width 0.3s; }
.section-h { display: flex; justify-content: space-between; align-items: baseline; padding: 32rpx 0 16rpx; }
.section-h .t { font-family: "Songti SC", serif; font-size: 32rpx; font-weight: 700; }
.section-h .more { font-size: 20rpx; color: var(--vermillion); letter-spacing: 0.2em; }
.list { padding-bottom: 40rpx; }
.todo { display: flex; gap: 24rpx; padding: 28rpx 0; border-bottom: 1rpx dashed var(--ink-4); align-items: flex-start; }
.check { width: 40rpx; height: 40rpx; border: 3rpx solid var(--ink); border-radius: 50%; flex-shrink: 0; margin-top: 4rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; }
.check.checked { background: var(--vermillion); border-color: var(--vermillion); color: var(--paper); }
.body { flex: 1; min-width: 0; }
.t-title { font-family: "Songti SC", serif; font-size: 30rpx; line-height: 1.3; }
.todo.done .t-title { text-decoration: line-through; color: var(--ink-4); }
.meta { display: flex; gap: 8rpx; margin-top: 12rpx; flex-wrap: wrap; }
.pin { color: var(--vermillion); font-size: 24rpx; margin-left: auto; }
.fab { position: fixed; right: 56rpx; bottom: 160rpx; width: 112rpx; height: 112rpx; background: var(--ink); color: var(--paper); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 56rpx; font-weight: 300; box-shadow: 0 24rpx 48rpx -16rpx rgba(26,22,18,.4); }
