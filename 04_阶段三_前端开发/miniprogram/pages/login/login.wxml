<view class="login">
  <view class="brand">
    <view class="dot"></view>
    <text class="name">待办 · TODO</text>
  </view>

  <view class="title">
    <text>你好，</text>
    <text class="accent">欢迎回来</text>
    <text>。</text>
  </view>
  <view class="sub">登录后即可查看、管理你今日所有的待办事项，让每一项任务都井然有序。</view>

  <view class="field">
    <text class="lbl">ACCOUNT · 账号</text>
    <input class="ipt" placeholder="请输入用户名" bindinput="onUsername" value="{{username}}" />
  </view>
  <view class="field">
    <text class="lbl">PASSWORD · 密码</text>
    <input class="ipt" password placeholder="请输入密码" bindinput="onPassword" value="{{password}}" />
  </view>

  <view class="btn" bindtap="onLogin">登 录</view>
  <view class="alt">还没有账号？<text class="link" bindtap="goRegister">立即注册</text></view>

  <view class="quote">把每一件小事做到极致，便是不凡。</view>
</view>
